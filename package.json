{
  "name": "xray-action",
  "version": "3.2.0",
  "private": true,
  "description": "GitHub action to import test results into 'Xray' - A complete Test Management tool for Jira.",
  "main": "lib/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "format-fix": "eslint --fix src/**.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "vitest --run --reporter=default",
    "all": "npm run build && npm run format && npm run lint && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikepenz/xray-action.git"
  },
  "keywords": [
    "actions",
    "xray",
    "junit",
    "cucumber",
    "behave",
    "testng",
    "nunit",
    "xunit",
    "robot",
    "bundle"
  ],
  "author": "Mike Penz",
  "license": "Apache 2.0",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/glob": "^0.6.1",
    "@supercharge/promise-pool": "^3.2.0",
    "@types/mime-types": "^3.0.1",
    "form-data": "^4.0.4",
    "got": "14.4.7",
    "junit-report-merger": "^7.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/eslint-scope": "^9.1.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "typescript": "^5.9.3"
  }
}
