{
  "name": "xray-action",
  "version": "4.1.0",
  "private": true,
  "description": "GitHub action to import test results into 'Xray' - A complete Test Management tool for Jira.",
  "main": "lib/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "format-fix": "eslint --fix src/**.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "vitest --run --reporter=default",
    "all": "npm run build && npm run format && npm run lint && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikepenz/xray-action.git"
  },
  "keywords": [
    "actions",
    "xray",
    "junit",
    "cucumber",
    "behave",
    "testng",
    "nunit",
    "xunit",
    "robot",
    "bundle"
  ],
  "author": "Mike Penz",
  "license": "Apache 2.0",
  "dependencies": {
    "@actions/core": "3.0.0",
    "@actions/glob": "0.6.1",
    "@supercharge/promise-pool": "3.3.0",
    "form-data": "4.0.5",
    "got": "15.0.1",
    "junit-report-merger": "9.0.3",
    "mime-types": "3.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vercel/ncc": "0.38.4",
    "eslint": "10.2.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-github": "6.0.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.5.0",
    "js-yaml": "4.1.1",
    "prettier": "3.8.2",
    "typescript": "6.0.2",
    "vitest": "4.1.4",
    "@types/mime-types": "3.0.1"
  },
  "overrides": {
    "typescript": "6.0.2",
    "brace-expansion": "5.0.5",
    "vite": "8.0.5"
  }
}
